{
  "legislative_session": "2026R1",
  "identifier": "SB1556",
  "title": "Relating to representation of persons in the magistrate division of the Oregon Tax Court; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Consolidates statutes governing the representation of parties before the magistrate division of the Oregon Tax Court. Applies to proceedings commenced on or after January 1, 2027. Takes effect on the 91st day following adjournment sine die."
    }
  ],
