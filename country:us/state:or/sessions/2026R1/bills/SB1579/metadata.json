{
  "legislative_session": "2026R1",
  "identifier": "SB1579",
  "title": "Relating to false reports of child abuse; prescribing an effective date.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Modifies the offense of making a false report of child abuse. Punishes a first offense by a maximum of six months' imprisonment, $2,500 fine, or both. Punishes a second offense by a maximum of 364 days' imprisonment, $6,250 fine, or both. Punishes a third or subsequent offense by a maximum of five years' imprisonment, $125,000 fine, or both. Takes effect on the 91st day following adjournment sine die."
    }
  ],
