{
  "legislative_session": "2026R1",
  "identifier": "HB4054",
  "title": "Relating to downcoding.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires certain health insurers offering a health benefit plan in this state that provide utilization review or have utilization review provided on their behalf to notify a health care provider each time the insurer uses artificial intelligence or other automated technology to automatically downcode a claim for reimbursement submitted by the provider. Requires insurers to make an appeals process available to a provider who has had a claim automatically downcoded using artificial intelligence or other automated technology."
    }
  ],
