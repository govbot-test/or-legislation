  "legislative_session": "2026R1",
  "identifier": "HB4047",
  "title": "Relating to rural emergency hospitals; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the Oregon Health Authority to adopt rules and procedures to allow a hospital to apply for a license as a rural emergency hospital. Takes effect on the 91st day following adjournment sine die."
    }
  ],
