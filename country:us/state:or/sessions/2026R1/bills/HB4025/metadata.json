{
  "legislative_session": "2026R1",
  "identifier": "HB4025",
  "title": "Relating to the residential rates of public utilities; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows an increase in the residential rates of a public utility to take effect from November 1 to March 31 for public utilities other than public utilities that provide electricity or natural gas services. Takes effect on the 91st day following adjournment sine die."
    }
  ],
