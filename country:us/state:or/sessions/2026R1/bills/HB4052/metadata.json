{
  "legislative_session": "2026R1",
  "identifier": "HB4052",
  "title": "Relating to a tax credit for de novo banks; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates a corporate excise tax credit for each of the first three years that a bank does business in this state. Applies only to Oregon-chartered banks that commence business in tax years beginning on or after January 1, 2027, and before January 1, 2033. Takes effect on the 91st day following adjournment sine die."
    }
  ],
