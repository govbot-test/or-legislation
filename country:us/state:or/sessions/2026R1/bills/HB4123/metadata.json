{
  "legislative_session": "2026R1",
  "identifier": "HB4123",
  "title": "Relating to landlord disclosure of confidential information; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Limits the circumstances under which a landlord may disclose confidential information. Authorizes statutory damages for individuals affected by knowing violations. Takes effect on the 91st day following adjournment sine die."
    }
  ],
