{
  "legislative_session": "2026R1",
  "identifier": "SB1537",
  "title": "Relating to boards of education of community college districts; declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the members of a board of education of a community college district to have an official electronic mail address that is posted on a publicly accessible website. Requires the board to include at least one nonvoting member of the board who is a student at a community college in the district. Requires the board to report to the Legislative Assembly on the board's compliance with certain provisions of the Act. Modifies requirements for filling vacancies on the board. Declares an emergency, effective on passage."
    }
  ],
