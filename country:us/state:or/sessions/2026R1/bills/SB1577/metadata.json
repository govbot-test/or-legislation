{
  "legislative_session": "2026R1",
  "identifier": "SB1577",
  "title": "Relating to the labeling of alternative protein food products.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides that a manufactured-protein food product that bears a label suggesting that the food product is made from meat is misbranded unless the food product label contains text disclosing that the food product is not made from meat. Provides that a fabricated-egg food product that bears a label suggesting that the food product is made from eggs is misbranded unless the food product label contains text disclosing that the food product is not made from eggs."
    }
  ],
