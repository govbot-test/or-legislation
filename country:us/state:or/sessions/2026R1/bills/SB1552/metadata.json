  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the county clerk to notify the owner of real property when an instrument affecting the title to the property is presented for recordation unless presented by a financial institution, an insurer or an attorney, or an employee or agent of the professional person. Declares an emergency, effective on passage."
    }
