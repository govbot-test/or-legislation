  "legislative_session": "2026R1",
  "identifier": "SB1590",
  "title": "Relating to public lands; and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits public bodies from assisting the federal government with privatization of certain federally owned lands. Sunsets January 2, 2032. Declares an emergency, effective on passage."
    }
