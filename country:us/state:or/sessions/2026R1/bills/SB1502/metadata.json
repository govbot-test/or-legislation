{
  "legislative_session": "2026R1",
  "identifier": "SB1502",
  "title": "Relating to proposed legislative measures to be filed by the Secretary of State; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Directs the Secretary of State to presession file a proposed legislative measure for consideration during the 2027 regular session of the Legislative Assembly that sets forth the recommendations of the secretary for changes to campaign finance limitations presently being implemented in this state. Takes effect on the 91st day following adjournment sine die."
    }
  ],
