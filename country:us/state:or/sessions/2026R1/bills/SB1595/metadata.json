{
  "legislative_session": "2026R1",
  "identifier": "SB1595",
  "title": "Relating to professional workforce; and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires a professional licensing board to publish specified guidance regarding licensure and ensure certain staff receive culturally responsive training not later than January 1, 2028. Declares an emergency, effective on passage."
    }
  ],
