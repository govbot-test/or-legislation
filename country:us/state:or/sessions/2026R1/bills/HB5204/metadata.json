  "abstracts": [
    {
      "note": "summary",
      "abstract": "<b>Establishes and</b> modifies certain biennial appropriations made from the General Fund to specified state agencies and the Emergency Board. Establishes and modifies limitations on expenditures for certain biennial expenses for specified state agencies. Declares an emergency, effective on passage."
    }
  ],
