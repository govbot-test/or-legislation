  "abstracts": [
    {
      "note": "summary",
      "abstract": "Designates the first Saturday of October of each year through the end of the Sunday of the following weekend as Water Professionals Appreciation Week. <b>Takes effect on the 91st day following adjournment sine die.</b>"
