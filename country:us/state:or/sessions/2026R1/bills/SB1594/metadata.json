{
  "legislative_session": "2026R1",
  "identifier": "SB1594",
  "title": "Relating to immigration; and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the Department of Justice to consult with the Office of Immigrant and Refugee Advancement when the department develops, reviews or updates model policies intended to limit immigration enforcement at public facilities. Declares an emergency, effective on passage."
    }
  ],
