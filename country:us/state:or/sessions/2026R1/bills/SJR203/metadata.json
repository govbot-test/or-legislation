{
  "legislative_session": "2026R1",
  "identifier": "SJR203",
  "title": "Proposing an amendment to the Oregon Constitution relating to the identifiability of law enforcement officers.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "</b> </i>] Proposes an amendment to the Oregon Constitution [<i>providing that law enforcement officers may not be masked and must wear certain identifying information except in specified circumstances</i>]<b> establishing a right to be free from enforcement of the law by secret police</b>. Refers the proposed amendment to the people for their approval or rejection at the next regular general election."
    }
  ],
