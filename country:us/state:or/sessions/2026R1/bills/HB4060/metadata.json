  "identifier": "HB4060",
  "title": "Relating to fluorescent lamps; declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Exempts sales to purchasers with facilities totaling more than one million square feet from a prohibition on sales of certain fluorescent lamps until January 1, 2030. Declares an emergency, effective on passage."
    }
