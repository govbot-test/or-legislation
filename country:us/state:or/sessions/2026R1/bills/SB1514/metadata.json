{
  "legislative_session": "2026R1",
  "identifier": "SB1514",
  "title": "Relating to the regulation of public property with respect to persons experiencing homelessness; declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Repeals the statute enacted by House Bill 3115 (2021) that established objective reasonableness as a statewide standard, for city and county laws regulating the use of public property with respect to persons experiencing homelessness, as the basis for a cause of action for injunctive and declaratory relief to challenge such laws and as an affirmative defense in the prosecution of violations of such laws. Declares an emergency, effective on passage."
    }
  ],
