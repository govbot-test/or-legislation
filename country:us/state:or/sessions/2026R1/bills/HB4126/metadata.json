  "legislative_session": "2026R1",
  "identifier": "HB4126",
  "title": "Relating to road usage charges; declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the Department of Transportation to submit a biennial report to the Legislative Assembly recommending a rate for the per-mile road usage charge that would sustainably raise the revenue necessary to maintain the public highways in this state. Declares an emergency, effective on passage."
    }
  ],
