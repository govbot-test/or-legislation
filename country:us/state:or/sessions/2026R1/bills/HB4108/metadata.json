{
  "legislative_session": "2026R1",
  "identifier": "HB4108",
  "title": "Relating to annexation of land noncontiguous to a city.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows the City of Eugene to annex noncontiguous land upon receipt of a petition from all owners of the land that satisfies four eligibility criteria."
    }
  ],
