  "legislative_session": "2026R1",
  "identifier": "HB4096",
  "title": "Relating to felon in possession of a firearm.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Creates the crime of aggravated felon in possession of a firearm when a person who has been convicted of a felony possesses three or more firearms or has certain prior convictions. Punishes by a maximum of 10 years' imprisonment, $250,000 fine, or both."
    }
  ],
