{
  "legislative_session": "2026R1",
  "identifier": "SB1511",
  "title": "Relating to the estate tax; prescribing an effective date.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "</b> </i>] [<i>Requires the Legislative Revenue Officer to study the estate tax. Directs the Legislative Revenue Officer to submit findings to the interim committees of the Legislative Assembly related to revenue not later than December 1, 2027.</i>] <b>Converts the $1 million exclusion for an estate subject to tax to a deduction of $2.5 million. Phases in the tax above the deduction. Raises the filing threshold for an estate tax return. Adjusts the deduction and filing threshold for inflation. Adjusts estate tax rates.</b> <b>Applies to the estates of decedents dying on or after January 1, 2027. </b> <b>Takes effect on the 91st day following adjournment sine die.</b>"
    }
  ],
