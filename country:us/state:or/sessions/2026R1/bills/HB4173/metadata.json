  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the Oregon Government Ethics Commission to study public meetings. Directs the commission to submit findings to the interim committees of the Legislative Assembly related to the judiciary no later than September 15, 2027. Sunsets on January 2, 2028."
