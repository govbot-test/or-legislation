  "identifier": "HB4050",
  "title": "Relating to funding for education; declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the Legislative Policy and Research Director to study processes to align educational funding with educational costs. Directs the director to submit a report to the interim committees of the Legislative Assembly related to education no later than November 15, 2026. Sunsets on January 2, 2027. Declares an emergency, effective on passage."
    }
  ],
