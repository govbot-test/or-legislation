{
  "legislative_session": "2026R1",
  "identifier": "SB1517",
  "title": "Relating to civil litigation; and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "</b> </i>] Provides that an operator may require a participant in a sport, fitness or recreational activity to release the operator for claims for ordinary negligence under certain circumstances. Specifies certain types of claims that may not be waived. <b>Provides that in a claim for damages for injuries sustained while a participant is engaged in a sport, fitness or recreational activity, whether a risk is inherent to the activity is a question of law.</b> Declares an emergency, effective on passage."
    }
  ],
