  "identifier": "SB1530",
  "title": "Relating to crime; declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Expands the crime of aggravated harassment to include threats concerning public officials in specified circumstances. Punishes by a maximum of five years' imprisonment, a fine of up to $125,000, or both. Declares an emergency, effective on passage."
    }
  ],
