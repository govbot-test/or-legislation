{
  "legislative_session": "2026R1",
  "identifier": "HB4131",
  "title": "Relating to mobile pharmacies; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Directs the State Board of Pharmacy to issue a license to operate a mobile pharmacy to a qualified applicant. Establishes requirements for a mobile pharmacy. Takes effect on the 91st day following adjournment sine die."
    }
  ],
