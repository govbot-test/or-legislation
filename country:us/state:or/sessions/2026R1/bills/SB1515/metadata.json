{
  "legislative_session": "2026R1",
  "identifier": "SB1515",
  "title": "Relating to wrongful convictions; and declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Modifies provisions relating to petitions for compensation for wrongful conviction. Creates a new post-conviction relief petition process when a person has a conviction that is based on scientific expert testimony, scientific expert evidence or scientific expert opinion derived from specified discredited forensic science disciplines. Sunsets the new petition process on January 2, 2031. Declares an emergency, effective on passage."
    }
  ],
