  "abstracts": [
    {
      "note": "summary",
      "abstract": "Exempts packaging for certain berries and meat, poultry, fish and seafood from producer responsibility requirements for packaging, paper and food serviceware. Takes effect on the 91st day following adjournment sine die."
    }
