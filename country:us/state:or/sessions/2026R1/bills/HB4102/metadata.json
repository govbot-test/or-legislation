  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Modifies the authority of the Department of Environmental Quality to enter into agreements with regulated entities to expedite or enhance a regulatory process. Takes effect on the 91st day following adjournment sine die."
    }
