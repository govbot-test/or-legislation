{
  "legislative_session": "2026R1",
  "identifier": "SB1555",
  "title": "Relating to the constitutional requirements for public education appropriations; declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Directs the Joint Interim Committee on Ways and Means to use a cost model for the purpose of calculating the sum of moneys sufficient to meet the state's system of public education quality goals. Modifies the public education quality goals for the purpose of the cost model and makes related changes specifying when a school district is a standard school district. Abolishes a joint committee related to the appropriation of moneys for public education. Abolishes the Quality Education Commission. Declares an emergency, effective on passage."
    }
  ],
