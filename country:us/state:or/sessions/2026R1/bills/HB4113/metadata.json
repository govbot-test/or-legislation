  "identifier": "HB4113",
  "title": "Relating to housing development opportunities conditioned upon land conservation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the Department of Land Conservation and Development to study housing development opportunities conditioned upon land conservation. Directs the department to submit findings to the interim committees of the Legislative Assembly related to land use no later than September 15, 2027. Sunsets on January 2, 2028."
    }
  ],
