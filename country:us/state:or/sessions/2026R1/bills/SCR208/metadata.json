{
  "legislative_session": "2026R1",
  "identifier": "SCR208",
  "title": "Amending Legislative Branch Personnel Rule 27 and adopting Legislative Branch Personnel Rule 27-C.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Modifies Legislative Branch Personnel Rule 27 to combine conduct report and conduct complaint processes into a single process. Provides that only the final investigative report is disclosable to the public, under certain conditions. Authorizes the Legislative Equity Officer to seek a voluntary resolution of investigations. Permits participating impacted parties to withdraw allegations under certain circumstances. Authorizes the officer to continue investigations even without the participation of any impacted party if evidence supports continuing the investigation. Establishes definitions of \"legislative business\" and \"workplace\" for determining application of the rule. Modifies other definitions and makes the role of investigator the same without regard to impacted parties or respondents. Applies to conduct reports and complaint statements made on or after the date of the adoption of the concurrent resolution, and to investigations of those reports and statements."
    }
  ],
