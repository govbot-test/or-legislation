{
  "legislative_session": "2026R1",
  "identifier": "HB4082",
  "title": "Relating to housing for older persons; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Adds to a temporary UGB addition program an option for each city or Metro to also add to its urban growth boundary a site for manufactured dwellings, prefabricated structures or manufactured dwelling parks, or for housing that is predominantly for older persons and affordable for households with incomes not more than 120 percent of area median income. Sunsets January 2, 2033. Takes effect on the 91st day following adjournment sine die."
    }
  ],
