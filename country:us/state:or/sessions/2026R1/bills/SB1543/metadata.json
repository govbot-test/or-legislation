{
  "legislative_session": "2026R1",
  "identifier": "SB1543",
  "title": "Relating to transportation; declaring an emergency.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Modifies membership of the Oregon Transportation Commission. Directs the commission to develop a debt financing management policy for all forms of debt financing issued to finance highway projects. Provides that before the Department of Transportation may request the State Treasurer to issue bonds, the department must first submit the proposed request to the Oregon Transportation Commission for review. Declares an emergency, effective on passage."
    }
  ],
