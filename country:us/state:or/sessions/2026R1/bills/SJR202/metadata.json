{
  "legislative_session": "2026R1",
  "identifier": "SJR202",
  "title": "Proposing an amendment to the Oregon Constitution relating to the duration of regular sessions of the Legislative Assembly.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Proposes an amendment to the Oregon Constitution to extend the duration of a regular session of the Legislative Assembly by one calendar day for each day that the Senate or the House of Representatives fails to achieve a quorum after attempting to do so. Refers the proposed amendment to the people for their approval or rejection at the next regular general election."
    }
  ],
