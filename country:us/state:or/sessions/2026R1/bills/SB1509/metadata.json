{
  "legislative_session": "2026R1",
  "identifier": "SB1509",
  "title": "Relating to electors of President and Vice President of the United States; and prescribing an effective date.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Establishes the qualifications of an elector of President and Vice President of the United States. Provides the contents of a certificate of ascertainment of electors. Provides that an elector who does not vote in accordance with the signed pledge of electors vacates the office of elector. Provides for the filling of the vacancy. Provides for mileage expenses to be given to electors who attend the meeting of electors and whose ballot is not invalid. Takes effect on July 1, 2026."
    }
  ],
