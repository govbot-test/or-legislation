{
  "legislative_session": "2026R1",
  "identifier": "SB1521",
  "title": "Relating to local requirements to develop affordable housing.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Prohibits cities and counties within the Portland MSA from enforcing requirements that developers provide affordable units in multiunit dwellings unless the city or county first calculates the developers' average expected losses due to providing affordable housing and the city or county offsets those losses. Becomes operative for rental housing on January 1, 2028. Becomes operative for all housing on January 1, 2029."
    }
  ],
