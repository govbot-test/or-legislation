{
  "legislative_session": "2026R1",
  "identifier": "HB4035",
  "title": "Relating to land use; and declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Expands eligibility for cities and Metro to amend their urban growth boundaries under a temporary program. <b>Provides an alternative pathway within the temporary program by which the City of Woodburn may amend its urban growth boundary.</b> Authorizes the Land Conservation and Development Commission to issue grants to implement the commission's duties. Declares an emergency, effective on passage."
    }
  ],
