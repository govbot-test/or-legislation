{
  "legislative_session": "2026R1",
  "identifier": "HB4137",
  "title": "Relating to the transfer of interest in motor vehicles.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Provides that, in lieu of making a first appearance for a traffic violation citation, the person who is the previous owner of a vehicle may notify the court that the person has transferred interest in the vehicle and is not liable for the citation."
    }
  ],
