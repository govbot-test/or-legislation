  "identifier": "HB4141",
  "title": "Relating to debt resolution services; prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires a person that provides debt resolution services to consumers in this state to register with the Department of Consumer and Business Services and regulates the activities of debt resolution service providers. Takes effect on the 91st day following adjournment sine die."
    }
  ],
