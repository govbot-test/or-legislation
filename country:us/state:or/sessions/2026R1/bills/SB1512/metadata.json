  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Expands the goals and purposes of the Prosperity 10,000 Program. Requires the Higher Education Coordinating Commission to award grants to local workforce development boards to administer the program. Requires local workforce development boards to consider certain factors when distributing funds to certain entities."
    }
  ],
