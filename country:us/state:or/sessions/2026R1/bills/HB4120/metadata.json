  "identifier": "HB4120",
  "title": "Relating to smoking policies in residential tenancies.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows residential landlords of multifamily housing to convert premises to nonsmoking for existing tenants upon [<i>90</i>]<b> 180</b> days' written notice. Applies to new and existing rental agreements."
    }
  ],
