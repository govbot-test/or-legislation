  "abstracts": [
    {
      "note": "summary",
      "abstract": "Expands the types of adverse licensing actions the Department of Human Services may take against child-caring agencies following certain findings. Modifies certain provisions regarding the use of restraints on children in care. Creates exceptions to certain placement limitations."
    }
  ],
