{
  "legislative_session": "2026R1",
  "identifier": "SB1563",
  "title": "Relating to civil rights; prescribing an effective date.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Allows a person who has been deprived of rights, privileges or immunities secured by the Oregon Constitution or the laws of this state by a person acting under color of law to bring a civil action for economic and noneconomic damages and for injunctive or other equitable relief. Provides for the award of attorney fees and costs to a prevailing plaintiff, or to a prevailing defendant if the court finds that a plaintiff's claim was frivolous, unreasonable or without foundation. Takes effect on the 91st day following adjournment sine die."
    }
  ],
