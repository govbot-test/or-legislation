{
  "legislative_session": "2026R1",
  "identifier": "SB1526",
  "title": "Relating to the facilitation of projects.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires the State Department of Energy to apply for grant moneys from the State Agency Program Fund to cover the costs and expenses of carrying out pre-startup activities and forming a nonprofit entity. Allows the department to also apply for moneys from other sources. Directs the department to carry out pre-startup activities, including [<i>recruiting and</i>] convening a founding board<b> and filling the founding board's membership</b>, if the department secures sufficient grant moneys. Directs the founding board to form a nonprofit entity for the purpose of financing clean energy and resilience projects. Requires the entity to report annually to the appropriate committees or interim committees of the Legislative Assembly. Directs the Oregon Business Development Department and the State Department of Energy to work with the entity."
    }
  ],
