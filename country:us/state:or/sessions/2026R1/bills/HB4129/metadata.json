  "legislative_session": "2026R1",
  "identifier": "HB4129",
  "title": "Relating to fuel; prescribing an effective date.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Limits greenhouse gas emission reductions, for purposes of low carbon fuel standards, to 10 percent below 2010 levels. Prohibits local governments from prohibiting or limiting the storage capacity of fossil fuel terminals. Takes effect on the 91st day following adjournment sine die."
    }
  ],
