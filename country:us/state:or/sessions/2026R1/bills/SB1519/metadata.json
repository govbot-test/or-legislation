{
  "legislative_session": "2026R1",
  "identifier": "SB1519",
  "title": "Relating to total disability.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "</b> </i>] [<i>Provides that the percentage of a worker's wage paid as compensation during a period of temporary total disability shall be determined by the portion of the worker's wage that is less than or equal to, or greater than, 75 percent of the state average weekly wage.</i>] <b>Changes the formula for determining permanent and temporary total disability compensation.</b>"
    }
  ],
