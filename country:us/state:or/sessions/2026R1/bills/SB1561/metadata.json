{
  "legislative_session": "2026R1",
  "identifier": "SB1561",
  "title": "Relating to restoration of dwellings damaged by involuntary causes.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Requires local governments to approve restoration or replacement of dwellings rendered uninhabitable under an alternative process that is not a land use decision."
    }
  ],
