  "abstracts": [
    {
      "note": "summary",
      "abstract": "</b> </i>] [<i>Requires the Oregon Health Authority to study health care. Directs the authority to submit findings to the interim committees of the Legislative Assembly related to health care no later than September 15, 2027.</i>] [<i>Sunsets on January 2, 2028.</i>] <b>Expands drug manufacturer annual reporting requirements to include all patient assistance programs offered or funded by the manufacturer that provided assistance to consumers in this state in the previous calendar year. Becomes operative on January 1, 2028.</b>"
    }
  ],
