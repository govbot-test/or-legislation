{
  "legislative_session": "2026R1",
  "identifier": "HB4105",
  "title": "Relating to reliable forest management outcomes; declaring an emergency.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Directs the State Forester to determine the available state forestland, establish sustainable harvest levels for harvesting timber on state forestland and manage available state forestland. Allows certain persons to seek a court order if the State Forester fails to establish sustainable harvest levels or manage available state forestland. Declares an emergency, effective on passage."
    }
  ],
